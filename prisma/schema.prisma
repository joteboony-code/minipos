generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  CASH
  TRANSFER
}

enum StockMovementType {
  SALE
  RECEIVE
  ADJUST
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id               String          @id @default(cuid())
  barcode          String          @unique
  name             String
  categoryId       String?
  category         Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  costPrice        Decimal         @db.Decimal(10, 2)
  salePrice        Decimal         @db.Decimal(10, 2)
  stockQty         Int             @default(0)
  unit             String          @default("ชิ้น")
  lowStockAlertQty Int             @default(5)
  isActive         Boolean         @default(true)
  isQuickSale      Boolean         @default(false)
  saleItems        SaleItem[]
  stockMovements   StockMovement[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([name])
  @@index([categoryId])
}

model Sale {
  id            String        @id @default(cuid())
  receiptNo     String        @unique
  totalAmount   Decimal       @db.Decimal(10, 2)
  totalCost     Decimal       @db.Decimal(10, 2)
  grossProfit   Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  cashReceived  Decimal?      @db.Decimal(10, 2)
  changeAmount  Decimal?      @db.Decimal(10, 2)
  idempotencyKey String?       @unique
  items         SaleItem[]
  createdAt     DateTime      @default(now())

  @@index([createdAt])
}

model SaleItem {
  id                  String  @id @default(cuid())
  saleId              String
  sale                Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId           String
  product             Product @relation(fields: [productId], references: [id])
  productNameSnapshot String
  barcodeSnapshot     String
  quantity            Int
  unitPrice           Decimal @db.Decimal(10, 2)
  costPrice           Decimal @db.Decimal(10, 2)
  lineTotal           Decimal @db.Decimal(10, 2)
  lineProfit          Decimal @db.Decimal(10, 2)
}

model StockMovement {
  id             String            @id @default(cuid())
  productId      String
  product        Product           @relation(fields: [productId], references: [id])
  type           StockMovementType
  quantityChange Int
  beforeQty      Int
  afterQty       Int
  note           String?
  createdAt      DateTime          @default(now())

  @@index([productId])
  @@index([createdAt])
}
