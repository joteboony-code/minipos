generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  CASH
  TRANSFER
  CREDIT
}

enum StockMovementType {
  SALE
  RECEIVE
  ADJUST
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id               String          @id @default(cuid())
  barcode          String          @unique
  name             String
  categoryId       String?
  category         Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  costPrice        Decimal         @db.Decimal(10, 2)
  salePrice        Decimal         @db.Decimal(10, 2)
  stockQty         Int             @default(0)
  unit             String          @default("ชิ้น")
  lowStockAlertQty Int             @default(5)
  isActive         Boolean         @default(true)
  isQuickSale      Boolean         @default(false)
  saleItems        SaleItem[]
  saleReturnItems  SaleReturnItem[]
  stockMovements   StockMovement[]
  productBatches   ProductBatch[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([name])
  @@index([categoryId])
}

model Sale {
  id                  String        @id @default(cuid())
  receiptNo           String        @unique
  totalAmount         Decimal       @db.Decimal(10, 2)
  totalCost           Decimal       @db.Decimal(10, 2)
  grossProfit         Decimal       @db.Decimal(10, 2)
  paymentMethod       PaymentMethod
  cashReceived        Decimal?      @db.Decimal(10, 2)
  changeAmount        Decimal?      @db.Decimal(10, 2)
  creditCustomerName  String?
  creditCustomerPhone String?
  creditNote          String?
  creditDueAmount     Decimal?      @default(0) @db.Decimal(10, 2)
  creditPaidAmount    Decimal?      @default(0) @db.Decimal(10, 2)
  creditStatus        String?
  idempotencyKey      String?       @unique
  status              String        @default("COMPLETED")
  voidedAt            DateTime?
  voidReason          String?
  voidedByRole        String?
  items               SaleItem[]
  creditPayments      CreditPayment[]
  returns             SaleReturn[]
  createdAt           DateTime      @default(now())

  @@index([createdAt])
  @@index([paymentMethod])
  @@index([creditStatus])
  @@index([status])
}

model SaleItem {
  id                  String  @id @default(cuid())
  saleId              String
  sale                Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId           String
  product             Product @relation(fields: [productId], references: [id])
  productNameSnapshot String
  barcodeSnapshot     String
  quantity            Int
  unitPrice           Decimal @db.Decimal(10, 2)
  costPrice           Decimal @db.Decimal(10, 2)
  lineTotal           Decimal @db.Decimal(10, 2)
  lineProfit          Decimal @db.Decimal(10, 2)
  itemBatches         SaleItemBatch[]
  returnItems         SaleReturnItem[]
}

model ProductBatch {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  receivedQty  Int
  remainingQty Int
  unitCost     Decimal         @db.Decimal(10, 2)
  note         String?
  receivedAt   DateTime        @default(now())
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  saleItems    SaleItemBatch[]

  @@index([productId, receivedAt])
  @@index([productId, remainingQty])
  @@index([receivedAt])
}

model SaleItemBatch {
  id             String       @id @default(cuid())
  saleItemId     String
  saleItem       SaleItem     @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  productBatchId String
  productBatch   ProductBatch @relation(fields: [productBatchId], references: [id])
  quantity       Int
  unitCost       Decimal      @db.Decimal(10, 2)
  totalCost      Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())

  @@index([saleItemId])
  @@index([productBatchId])
}

model StockMovement {
  id             String            @id @default(cuid())
  productId      String
  product        Product           @relation(fields: [productId], references: [id])
  type           StockMovementType
  quantityChange Int
  beforeQty      Int
  afterQty       Int
  note           String?
  createdAt      DateTime          @default(now())

  @@index([productId])
  @@index([createdAt])
}

model CreditPayment {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(10, 2)
  note      String?
  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([createdAt])
}

model SaleReturn {
  id        String           @id @default(cuid())
  saleId    String
  sale      Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  reason    String?
  items     SaleReturnItem[]
  createdAt DateTime         @default(now())

  @@index([saleId])
  @@index([createdAt])
}

model SaleReturnItem {
  id           String     @id @default(cuid())
  saleReturnId String
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  saleItemId   String
  saleItem     SaleItem   @relation(fields: [saleItemId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Int
  refundAmount Decimal    @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())

  @@index([saleReturnId])
  @@index([saleItemId])
  @@index([productId])
}

model CashShift {
  id                 String    @id @default(cuid())
  openedByRole       String?
  openedAt           DateTime  @default(now())
  closedAt           DateTime?
  openingCash        Decimal   @db.Decimal(10, 2)
  closingCash        Decimal?  @db.Decimal(10, 2)
  expectedCash       Decimal?  @db.Decimal(10, 2)
  cashSalesTotal     Decimal   @default(0) @db.Decimal(10, 2)
  transferSalesTotal Decimal   @default(0) @db.Decimal(10, 2)
  creditSalesTotal   Decimal   @default(0) @db.Decimal(10, 2)
  totalSales         Decimal   @default(0) @db.Decimal(10, 2)
  billCount          Int       @default(0)
  note               String?
  status             String    @default("OPEN")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([openedAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorRole   String?
  action      String
  entityType  String
  entityId    String?
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([entityType])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
